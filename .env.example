MINIO_ROOT_PASSWORD=
MINIO_API_PORT=
MINIO_CONSOLE_PORT=

# =========================
# AWS S3（本番）/ MinIO（ローカル）共通
# =========================
AWS_REGION=ap-northeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
# ローカルのみ設定（MinIOを指す）。本番では設定しない。
AWS_ENDPOINT=

# =========================
# 各サービスのホスト側ポート
# =========================
FRONTEND_PORT=
BACKEND_PORT=
MYSQL_PORT=
NGINX_PORT=