# =========================
# アプリ共通
# =========================
NODE_ENV=

# =========================
# DB(MySQL)
# =========================
DB_HOST=
DB_PORT=
DB_USER=
DB_PASSWORD=
DB_NAME=
DATABASE_URL=

MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=                             

# =========================
# MailHog
# =========================
MAIL_HOST=
MAIL_PORT=

MAILHOG_WEB_PORT=
MAILHOG_SMTP_PORT=

# =========================
# MinIO（ローカル開発用）
# =========================
